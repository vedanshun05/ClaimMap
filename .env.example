# NVIDIA NIM API (for Gemini via litellm)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# Alternative: Direct Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Semantic Scholar API (optional, has rate limits)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# arXiv (no key required, but respect rate limits)
# ARXIV_API_KEY=not_required

# Project settings
DEFAULT_MODEL=nvidia_nim/meta/llama-3.1-8b-instruct

LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=20
