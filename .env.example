# OpenAI API key (primary LLM provider)
OPENAI_API_KEY=your_openai_api_key_here

# Backwards-compatible name if needed
# OPENCODE_API_KEY=also_supported_but_not_required

# Semantic Scholar API (optional, has rate limits)
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# Project settings
DEFAULT_MODEL=gpt-4.1-mini

LOG_LEVEL=INFO
MAX_PAPERS_PER_QUERY=20
